CHRONOS_LOG_LEVEL=debug
CHRONOS_BASE_URL=http://localhost:3000
CHRONOS_DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
# --------------------------------------------------
# | You have to change every value below this line |
# --------------------------------------------------
CHRONOS_AUTH_SECRET=FILL_ME_IN
CHRONOS_ADMIN_EMAIL=your.email.here@petrik.hu
CHRONOS_ENTRA_TENANT_ID=FILL_ME_IN
CHRONOS_ENTRA_CLIENT_ID=FILL_ME_IN
CHRONOS_ENTRA_CLIENT_SECRET=FILL_ME_IN

# --------------------------------------------------
# | Telemetry (Sentry) - Optional but recommended |
# --------------------------------------------------
# Sentry DSN for error tracking
# CHRONOS_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Environment name (defaults to CHRONOS_MODE value)
# CHRONOS_SENTRY_ENVIRONMENT=development

# Release version (defaults to package version)
# CHRONOS_SENTRY_RELEASE=chronos@1.0.0

# Error sampling rate (1.0 = 100%, 0.1 = 10%)
# CHRONOS_SENTRY_SAMPLE_RATE=1.0

# Performance tracing sample rate (0.1 = 10% recommended for production)
# CHRONOS_SENTRY_TRACES_SAMPLE_RATE=0.1

# --------------------------------------------------
# | Notification system                              |
# --------------------------------------------------
# SMTP configuration for email notifications
# CHRONOS_SMTP_HOST=mail.example.com
# CHRONOS_SMTP_PORT=587
# CHRONOS_SMTP_USER=
# CHRONOS_SMTP_PASS=
# CHRONOS_SMTP_FROM_NAME=Filc
# CHRONOS_SMTP_FROM_EMAIL=noreply@filc.hu
# CHRONOS_SMTP_SECURE=false

# Firebase Cloud Messaging for push notifications
# CHRONOS_FCM_CREDENTIALS={"type":"service_account",...}
# CHRONOS_FCM_PROJECT_ID=your-firebase-project-id

# Notification delays in seconds (wait period before sending)
# CHRONOS_NOTIFICATION_DELAY_SUBSTITUTION=60
# CHRONOS_NOTIFICATION_DELAY_MOVED_LESSON=60
# CHRONOS_NOTIFICATION_DELAY_ANNOUNCEMENT=60
# CHRONOS_NOTIFICATION_DELAY_SYSTEM_MESSAGE=60
# CHRONOS_NOTIFICATION_DELAY_BLOG_POST=60

# --------------------------------------------------
# | Rate limiting                                  |
# --------------------------------------------------
# Maximum requests per window per client (default: 180)
# CHRONOS_RATE_LIMIT_MAX=180

# Rate limit window in milliseconds (default: 30000 = 30 seconds)
# CHRONOS_RATE_LIMIT_WINDOW_MS=30000

# Cookie name for anonymous client identification (default: filc_rl_id)
# CHRONOS_RATE_LIMIT_COOKIE_NAME=filc_rl_id

# Header to read the real client IP from (e.g. X-Forwarded-For, CF-Connecting-IP)
# CHRONOS_REAL_IP_HEADER=X-Forwarded-For