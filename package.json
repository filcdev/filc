{
  "name": "@filcdev/filc",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.8",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "bunx biome check --write"
  },
  "packageManager": "bun@1.3.13",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "lint": "biome check --write .",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "prepare": "bun run .husky/install.ts || true"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.13",
      "typescript": "^6.0.3",
      "hono": "^4.12.16",
      "better-auth": "^1.6.9",
      "zod": "^4.4.2"
    }
  }
}
