{
  "name": "@filcdev/filc",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.10.5",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "bunx biome check --write"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "lint": "biome check --write .",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "prepare": "bun run .husky/install.ts || true"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.14",
      "typescript": "^7.0.2",
      "hono": "^4.12.30",
      "better-auth": "^1.6.23",
      "zod": "^4.4.3"
    }
  }
}
