{
  // Linting / Style
  "editor.tabSize": 2,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "editor.formatOnPaste": true,

  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "always",
    "source.fixAll.biome": "always"
  },

  // TypeScript
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,

  // i18n
  "i18n-ally.localesPaths": ["apps/iris/public/locales"],
  "i18n-ally.keystyle": "nested",
  "i18n-ally.enabledFrameworks": ["react"],

  // biome
  "biome.lsp.bin": "./node_modules/@biomejs/biome/bin/biome",
  "biome.requireConfiguration": false,

  // Copilot commit messages
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use conventional commit format: type(scope): description"
    },
    {
      "text": "Use imperative mood: 'Add feature' not 'Added feature'"
    },
    {
      "text": "Keep subject line under 50 characters"
    },
    {
      "text": "Use types: feat, fix, docs, style, refactor, chore, ci"
    },
    {
      "text": "Include scope when relevant (e.g., api, ui, auth)"
    },
    {
      "text": "Reference issue numbers with # prefix"
    }
  ],

  // mise
  "mise.configureExtensionsAutomatically": false
}
