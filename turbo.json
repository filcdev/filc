{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "dependsOn": [
        "^dev"
      ],
      "cache": false,
      "persistent": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [".cache/.eslintcache"]
    },
    "typecheck": {
      "dependsOn": ["^build", "@filc/db#generate"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "clean": {
      "cache": false
    },
    "@filc/frontend#dev": {
      "persistent": true
    },
    "@filc/backend#dev": {
      "persistent": true,
      "dependsOn": [
        "@filc/api#dev",
        "@filc/auth#dev",
        "@filc/config#dev",
        "@filc/db#dev",
        "@filc/rbac#dev"
      ]
    },
    "@filc/db#push": {
      "cache": false,
      "interactive": true
    },
    "@filc/db#studio": {
      "cache": false,
      "persistent": true
    },
    "@filc/db#generate": {
      "cache": false
    },
    "@filc/db#reset": {
      "cache": false
    }
  },
  "globalEnv": ["MODE"],
  "globalPassThroughEnv": ["NODE_ENV", "MODE", "CI", "npm_lifecycle_event"]
}
