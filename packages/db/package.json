{
  "name": "@filc/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsc",
    "build": "tsc && tsc-alias",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "prebuild": "pnpm run db:generate",
    "predev": "pnpm run db:generate",
    "prelint": "pnpm run db:generate",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev --skip-generate",
    "deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "push": "prisma db push",
    "reset": "prisma migrate reset --force && prisma db push --skip-generate"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@filc/eslint-config": "workspace:*",
    "@filc/prettier-config": "workspace:*",
    "@filc/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prisma": "^6.5.0",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@filc/config": "workspace:*",
    "@prisma/client": "^6.5.0"
  },
  "exports": {
    "import": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "main": "./src/index.ts",
  "prettier": "@filc/prettier-config"
}
